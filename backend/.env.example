# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
SLOW_DOWN_DELAY_MS=500
SLOW_DOWN_AFTER_REQUESTS=6

# CORS (set to exact production frontend URL)
# For Render: use your frontend service URL (e.g., https://code-to-doc-frontend.onrender.com)
CORS_ORIGIN=https://code-to-doc-frontend.onrender.com

# Frontend URL (for CORS)
# For Render: use your frontend service URL
FRONTEND_URL=https://code-to-doc-frontend.onrender.com
